{
  "name": "taskline-platform",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "lint": "node scripts/lint.mjs",
    "install:frontend": "npm --prefix frontend install",
    "install:backend": "npm --prefix backend install",
    "install:all": "npm run install:backend && npm run install:frontend",
    "dev:frontend": "npm --prefix frontend run dev",
    "start:backend": "npm --prefix backend run start",
    "build:frontend": "npm --prefix frontend run build",
    "build": "npm run build:frontend",
    "db:generate": "npm --prefix backend run db:generate",
    "db:migrate:dev": "npm --prefix backend run db:migrate:dev",
    "db:migrate:deploy": "npm --prefix backend run db:migrate:deploy"
  }
}
