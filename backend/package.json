{
  "name": "taskline-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --watch --env-file-if-exists=../.env server.js",
    "start": "node --env-file-if-exists=../.env server.js",
    "db:generate": "node --env-file-if-exists=../.env ./node_modules/prisma/build/index.js generate --schema prisma/schema.prisma",
    "db:migrate:dev": "node --env-file-if-exists=../.env ./node_modules/prisma/build/index.js migrate dev --schema prisma/schema.prisma",
    "db:migrate:deploy": "node --env-file-if-exists=../.env ./node_modules/prisma/build/index.js migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.16.2",
    "applicationinsights": "^3.14.0",
    "bcryptjs": "^3.0.3",
    "express": "^5.2.1",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.16.2",
    "prom-client": "^15.1.3"
  },
  "engines": {
    "node": ">=24"
  }
}
