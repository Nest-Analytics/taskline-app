{
  "name": "taskline-frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node --env-file-if-exists=../.env ./node_modules/vite/bin/vite.js",
    "build": "node --env-file-if-exists=../.env ./node_modules/vite/bin/vite.js build",
    "preview": "node --env-file-if-exists=../.env ./node_modules/vite/bin/vite.js preview --host 0.0.0.0 --port ${PORT:-4173}"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.2.2",
    "vite": "^5.4.14"
  },
  "engines": {
    "node": ">=24"
  }
}
